# Upstream Navidrome base URL (required).
NAVIDROME_URL=http://localhost:4533

# Address the proxy listens on (optional, default :8080).
LISTEN_ADDR=:8080

# SQLite play-history database path (optional, default ./data/maraetai.db).
DB_PATH=./data/maraetai.db

# docker-compose only: host path to your music library.
MUSIC_DIR=./music
